# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Fix: ensure dSYM is generated for all pod targets (including objective_c.framework)
      # so Xcode archive validation does not fail with "missing dSYM" errors.
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'

      # Fix: exclude arm64 simulator slice from simulator SDK builds.
      # Prevents App Store rejection: "unsupported platform in the arm64 slice"
      # caused by objective_c.framework (gRPC pod) including a simulator-tagged arm64 binary.
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
    end
  end

  # Patch apple_maps_flutter: fix [unowned self] crash (AppleMapController.swift:62)
  # When the map widget disposes, pending FlutterMethodChannel callbacks can fire
  # after AppleMapController is deallocated, causing swift_abortRetainUnowned.
  # Fix: replace [unowned self] with [weak self] + guard.
  # Remove this patch when apple_maps_flutter > 1.4.0 fixes the issue upstream.
  apple_map_controller = File.join(
    __dir__, '.symlinks', 'plugins', 'apple_maps_flutter',
    'ios', 'Classes', 'MapView', 'AppleMapController.swift'
  )
  if File.exist?(apple_map_controller)
    content = File.read(apple_map_controller)
    if content.include?('[unowned self]')
      patched = content.gsub(
        '[unowned self] (call: FlutterMethodCall, result: @escaping FlutterResult) -> Void in',
        "[weak self] (call: FlutterMethodCall, result: @escaping FlutterResult) -> Void in\n            guard let self = self else { result(FlutterMethodNotImplemented); return }"
      )
      File.write(apple_map_controller, patched)
      Pod::UI.puts "Patched apple_maps_flutter: [unowned self] → [weak self] in AppleMapController.swift"
    end
  end
end
